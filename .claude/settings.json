{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*credential*.json)",
      "Read(./**/*.db)",
      "Read(./**/*.db-wal)",
      "Read(./**/*.db-shm)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(.env*)",
      "Edit(./secrets/**)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./**/*credential*.json)",
      "Edit(./**/*.db)",
      "Edit(./**/*.db-wal)",
      "Edit(./**/*.db-shm)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(.env*)",
      "Write(./secrets/**)",
      "Write(./**/*.pem)",
      "Write(./**/*.key)",
      "Write(./**/*credential*.json)",
      "Write(./**/*.db)",
      "Write(./**/*.db-wal)",
      "Write(./**/*.db-shm)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(cat .env*)",
      "Bash(echo * > .env*)"
    ],
    "allow": [
      "Bash(ast-grep *)",
      "Bash(git status*)"
    ],
    "ask": [
      "Bash(npm install*)",
      "Bash(pnpm install*)"
    ],
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-claude-config.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-subagent-event.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-subagent-event.py\""
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-claude-config.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-reminder.py\""
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".env|.envrc|.env.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/warn-env-file-changed.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-sensitive-files.py\""
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-interceptor.sh\""
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-instructions-loaded.py\""
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/cwd-changed-reminder.py\""
          }
        ]
      }
    ]
  },
  "disableSkillShellExecution": false,
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "**/.env*",
        "**/*.pem",
        "~/.ssh/**"
      ],
      "allowWrite": [
        "${workspaceFolder}/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "api.github.com"
      ]
    }
  },
  "awsAuthRefresh": "aws sso login --profile enterprise-devsecops",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16384",
    "AST_L_MAX": "500",
    "AST_L_MIN": "100",
    "AST_OVERLAP": "50",
    "ENABLE_PROMPT_CACHING_1H": "1"
  }
}
