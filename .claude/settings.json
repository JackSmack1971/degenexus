{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*credential*.json)",
      "Read(./**/*.db)",
      "Read(./**/*.db-wal)",
      "Read(./**/*.db-shm)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(.env*)",
      "Edit(./secrets/**)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./**/*credential*.json)",
      "Edit(./**/*.db)",
      "Edit(./**/*.db-wal)",
      "Edit(./**/*.db-shm)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(.env*)",
      "Write(./secrets/**)",
      "Write(./**/*.pem)",
      "Write(./**/*.key)",
      "Write(./**/*credential*.json)",
      "Write(./**/*.db)",
      "Write(./**/*.db-wal)",
      "Write(./**/*.db-shm)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(cat .env*)",
      "Bash(echo * > .env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate-claude-config.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log-subagent-event.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/log-subagent-event.py"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate-claude-config.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session-start-reminder.py"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".env|.envrc|.env.*",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/warn-env-file-changed.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/protect-sensitive-files.py"
          }
        ]
      }
    ]
  }
}
